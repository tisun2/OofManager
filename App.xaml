<Application x:Class="OofManager.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:conv="clr-namespace:OofManager.Wpf.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <conv:InvertBoolConverter x:Key="InvertBool"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:OofStatusToTextConverter x:Key="OofStatusToText"/>
            <conv:TimeSpanToHourMinuteConverter x:Key="TimeSpanToHourMinute"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
