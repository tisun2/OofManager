<Page x:Class="OofManager.Wpf.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
      Title="Sign In">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Center">
            <Image Source="/Resources/oofmanager.ico" Width="96" Height="96" HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="OOF Manager"
                       FontSize="32" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                       Margin="0,10,0,0"/>
            <TextBlock Text="Out of Office Manager"
                       FontSize="16" Opacity="0.7"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"
                       Opacity="0.8"
                       TextWrapping="Wrap"
                       MaxWidth="500"
                       TextAlignment="Center"/>

            <Button Content="🔑  Sign in with Microsoft"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                    Style="{StaticResource AccentButtonStyle}"
                    FontSize="16"
                    Height="48"
                    Width="320"
                    HorizontalAlignment="Center"/>

            <ui:ProgressRing IsActive="{Binding IsBusy}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                             HorizontalAlignment="Center"
                             Margin="0,16,0,0"/>
        </StackPanel>
    </Grid>
</Page>
