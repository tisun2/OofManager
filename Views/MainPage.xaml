<Page x:Class="OofManager.Wpf.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:models="clr-namespace:OofManager.Wpf.Models"
      Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
      Title="OOF Manager">
    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <StackPanel.Resources>
                <Style TargetType="StackPanel">
                    <Setter Property="Margin" Value="0,0,0,16"/>
                </Style>
            </StackPanel.Resources>

            <!-- User Info Card -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0">
                        <TextBlock Text="{Binding UserDisplayName}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="{Binding UserEmail}" FontSize="13" Opacity="0.6"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="📥 Hide to Tray"
                            Command="{Binding HideToTrayCommand}"
                            ToolTip="Hide window to system tray; the app keeps running in the background"
                            VerticalAlignment="Center"
                            Padding="14,4"
                            Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="🔄 Switch account"
                            Command="{Binding SwitchAccountCommand}"
                            ToolTip="Sign out and pick a different Microsoft 365 account"
                            VerticalAlignment="Center"
                            Padding="14,4"/>

                    <CheckBox Grid.Row="1" Grid.ColumnSpan="3"
                              IsChecked="{Binding IsStartWithWindowsEnabled, Mode=TwoWay}"
                              Content="🚀 Start with Windows (launch hidden in the tray)"
                              FontSize="12"
                              Margin="0,12,0,0"
                              ToolTip="When on, OofManager launches automatically when you sign in to Windows and starts hidden in the system tray."/>
                </Grid>
            </Border>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                       Margin="0,2,0,14"
                       TextWrapping="Wrap"/>

            <!-- Quick Toggle Card -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0">
                        <TextBlock Text="Out of Office" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrentStatus, Converter={StaticResource OofStatusToText}}"
                                   FontSize="18" FontWeight="SemiBold" Opacity="0.85" Margin="0,4,0,0"/>
                        <!-- Sub-caption explains who's currently in charge of the
                             toggle, so the user can tell at a glance whether
                             they need to flip it themselves or whether the
                             schedule will do it. -->
                        <TextBlock FontSize="12" Opacity="0.65" Margin="0,4,0,0"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Manual control — flip the switch and click Save Now to push the change to Outlook."/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWorkScheduleEnabled}" Value="True">
                                            <Setter Property="Text" Value="Auto-managed by Work Schedule below. Turn that off if you want manual control."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Toggle: disabled (read-only state indicator) when the
                         Work Schedule is in charge, fully interactive when it
                         isn't. The bound value still reflects the current OOF
                         state in both modes. -->
                    <ui:ToggleSwitch Grid.Column="1"
                                     IsOn="{Binding IsOofEnabled, Mode=TwoWay}"
                                     IsEnabled="{Binding IsWorkScheduleEnabled, Converter={StaticResource InvertBool}}"
                                     VerticalAlignment="Center"/>

                    <!-- Save Now button only appears in manual mode; in
                         scheduled mode the auto-loop pushes the state for
                         the user, so a manual button would just be misleading. -->
                    <Button Grid.Row="1" Grid.ColumnSpan="2"
                            Content="⚡ Save Now"
                            Command="{Binding QuickToggleCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Height="44"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,12,0,0"
                            Visibility="{Binding IsWorkScheduleEnabled, Converter={StaticResource InvertBoolToVisibility}}"/>
                </Grid>
            </Border>

            <!-- Work Schedule Card -->
            <Border Style="{StaticResource CardStyle}">
                <!-- IsSharedSizeScope so the schedule grid and the button grid
                     below it agree on Auto-column widths (Day, Off Work) and
                     star-column widths (Start Time, End Time). Without this
                     each grid measures independently and the Save button's
                     right edge ends up shorter than the Start-time column. -->
                <StackPanel Margin="0" Grid.IsSharedSizeScope="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0">
                            <TextBlock Text="🗓️ Work Schedule" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{Binding WorkScheduleStatus}" FontSize="12" Opacity="0.65" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1"
                                         IsOn="{Binding IsWorkScheduleEnabled, Mode=TwoWay}"/>
                    </Grid>

                    <TextBlock Text="Check &quot;Off Work&quot; for any day you don't work. During each working day's hours OOF is turned off; outside those hours (and on off-work days) OOF is turned on automatically. Each day can have its own start and end time."
                               FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                               Margin="0,8,0,8"/>

                    <CheckBox IsChecked="{Binding IsAutoSyncEnabled, Mode=TwoWay}"
                              Content="🔄 Keep Outlook in sync automatically (recommended — works even when this app is closed)"
                              FontSize="12"
                              Margin="0,0,0,12"
                              ToolTip="When on, the next off-hours window is pushed to Outlook on every schedule check, so the server toggles OOF on/off even if this app isn't running."/>

                    <!-- Cloud sync setup. The local auto-sync above only works when this PC is on
                         (with the app or its background scheduled task running). For users who want
                         their OOF window to keep advancing even when ALL their computers are off,
                         the buttons below set up a Power Automate flow inside their M365 account.
                         "Download package" creates a one-click .zip the user uploads to Power
                         Automate; "Manual setup" generates a step-by-step HTML guide as a fallback
                         for tenants where legacy package import is disabled. -->
                    <Border Background="#E7F3FE" BorderBrush="#0078D4" BorderThickness="0,0,0,2" CornerRadius="4"
                            Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="🌐 Sync from the cloud (works when ALL your computers are off)"
                                       FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="The flow runs inside your Microsoft 365 account, so your OOF schedule keeps updating in Outlook even with every device powered down."
                                       FontSize="11" Opacity="0.75" TextWrapping="Wrap" Margin="0,3,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="📦 Download flow package"
                                        Command="{Binding GenerateCloudSyncPackageCommand}"
                                        Padding="12,6" HorizontalAlignment="Stretch"
                                        ToolTip="Generates a Power Automate import package on your Desktop and opens make.powerautomate.com so you can import it. Recommended."/>
                                <Button Grid.Column="2" Content="📖 Manual setup guide"
                                        Command="{Binding OpenCloudSyncGuideCommand}"
                                        Padding="12,6" HorizontalAlignment="Stretch"
                                        ToolTip="Fallback if your tenant blocks legacy package import. Opens a personalised HTML walkthrough in your browser."/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <!-- Outer 2-column 50/50 layout. Day + OffWork + Start
                             Time live INSIDE the left half so Start Time's
                             right edge naturally lands at the 50% midpoint;
                             that's also where the buttons grid below splits.
                             Result: Save button right edge == Start time right
                             edge, Sync now left edge == End time left edge. -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ================ Header row ================ -->
                        <Grid Grid.Row="0" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="48" SharedSizeGroup="DayCol"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="OffWorkCol"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Day" FontSize="12" Opacity="0.7" Margin="0,0,8,4"/>
                            <TextBlock Grid.Column="1" Text="Off Work" FontSize="12" Opacity="0.7" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Work Start Time" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                        </Grid>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Work End Time" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>

                        <!-- ================ Monday ================ -->
                        <Grid Grid.Row="1" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="48" SharedSizeGroup="DayCol"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="OffWorkCol"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mon" FontSize="13" VerticalAlignment="Center" Margin="0,4,8,0"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsMondayWorkday, Converter={StaticResource InvertBool}}"
                                      MinWidth="0" Padding="0"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <ComboBox Grid.Column="3"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      ItemsSource="{Binding WorkTimeOptions}"
                                      IsEnabled="{Binding IsMondayWorkday}"
                                      Text="{Binding MondayStartTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      HorizontalAlignment="Stretch" Margin="0,4,0,0"/>
                        </Grid>
                        <ComboBox Grid.Row="1" Grid.Column="2"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  ItemsSource="{Binding WorkTimeOptions}"
                                  IsEnabled="{Binding IsMondayWorkday}"
                                  Text="{Binding MondayEndTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  HorizontalAlignment="Stretch" Margin="0,4,0,0"/>

                        <!-- ================ Tuesday ================ -->
                        <Grid Grid.Row="2" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="48" SharedSizeGroup="DayCol"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="OffWorkCol"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Tue" FontSize="13" VerticalAlignment="Center" Margin="0,4,8,0"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsTuesdayWorkday, Converter={StaticResource InvertBool}}"
                                      MinWidth="0" Padding="0"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <ComboBox Grid.Column="3"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      ItemsSource="{Binding WorkTimeOptions}"
                                      IsEnabled="{Binding IsTuesdayWorkday}"
                                      Text="{Binding TuesdayStartTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      HorizontalAlignment="Stretch" Margin="0,4,0,0"/>
                        </Grid>
                        <ComboBox Grid.Row="2" Grid.Column="2"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  ItemsSource="{Binding WorkTimeOptions}"
                                  IsEnabled="{Binding IsTuesdayWorkday}"
                                  Text="{Binding TuesdayEndTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  HorizontalAlignment="Stretch" Margin="0,4,0,0"/>

                        <!-- ================ Wednesday ================ -->
                        <Grid Grid.Row="3" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="48" SharedSizeGroup="DayCol"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="OffWorkCol"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Wed" FontSize="13" VerticalAlignment="Center" Margin="0,4,8,0"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsWednesdayWorkday, Converter={StaticResource InvertBool}}"
                                      MinWidth="0" Padding="0"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <ComboBox Grid.Column="3"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      ItemsSource="{Binding WorkTimeOptions}"
                                      IsEnabled="{Binding IsWednesdayWorkday}"
                                      Text="{Binding WednesdayStartTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      HorizontalAlignment="Stretch" Margin="0,4,0,0"/>
                        </Grid>
                        <ComboBox Grid.Row="3" Grid.Column="2"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  ItemsSource="{Binding WorkTimeOptions}"
                                  IsEnabled="{Binding IsWednesdayWorkday}"
                                  Text="{Binding WednesdayEndTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  HorizontalAlignment="Stretch" Margin="0,4,0,0"/>

                        <!-- ================ Thursday ================ -->
                        <Grid Grid.Row="4" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="48" SharedSizeGroup="DayCol"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="OffWorkCol"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Thu" FontSize="13" VerticalAlignment="Center" Margin="0,4,8,0"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsThursdayWorkday, Converter={StaticResource InvertBool}}"
                                      MinWidth="0" Padding="0"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <ComboBox Grid.Column="3"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      ItemsSource="{Binding WorkTimeOptions}"
                                      IsEnabled="{Binding IsThursdayWorkday}"
                                      Text="{Binding ThursdayStartTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      HorizontalAlignment="Stretch" Margin="0,4,0,0"/>
                        </Grid>
                        <ComboBox Grid.Row="4" Grid.Column="2"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  ItemsSource="{Binding WorkTimeOptions}"
                                  IsEnabled="{Binding IsThursdayWorkday}"
                                  Text="{Binding ThursdayEndTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  HorizontalAlignment="Stretch" Margin="0,4,0,0"/>

                        <!-- ================ Friday ================ -->
                        <Grid Grid.Row="5" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="48" SharedSizeGroup="DayCol"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="OffWorkCol"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Fri" FontSize="13" VerticalAlignment="Center" Margin="0,4,8,0"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsFridayWorkday, Converter={StaticResource InvertBool}}"
                                      MinWidth="0" Padding="0"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <ComboBox Grid.Column="3"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      ItemsSource="{Binding WorkTimeOptions}"
                                      IsEnabled="{Binding IsFridayWorkday}"
                                      Text="{Binding FridayStartTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      HorizontalAlignment="Stretch" Margin="0,4,0,0"/>
                        </Grid>
                        <ComboBox Grid.Row="5" Grid.Column="2"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  ItemsSource="{Binding WorkTimeOptions}"
                                  IsEnabled="{Binding IsFridayWorkday}"
                                  Text="{Binding FridayEndTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  HorizontalAlignment="Stretch" Margin="0,4,0,0"/>

                        <!-- ================ Saturday ================ -->
                        <Grid Grid.Row="6" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="48" SharedSizeGroup="DayCol"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="OffWorkCol"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sat" FontSize="13" VerticalAlignment="Center" Margin="0,4,8,0"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsSaturdayWorkday, Converter={StaticResource InvertBool}}"
                                      MinWidth="0" Padding="0"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <ComboBox Grid.Column="3"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      ItemsSource="{Binding WorkTimeOptions}"
                                      IsEnabled="{Binding IsSaturdayWorkday}"
                                      Text="{Binding SaturdayStartTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      HorizontalAlignment="Stretch" Margin="0,4,0,0"/>
                        </Grid>
                        <ComboBox Grid.Row="6" Grid.Column="2"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  ItemsSource="{Binding WorkTimeOptions}"
                                  IsEnabled="{Binding IsSaturdayWorkday}"
                                  Text="{Binding SaturdayEndTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  HorizontalAlignment="Stretch" Margin="0,4,0,0"/>

                        <!-- ================ Sunday ================ -->
                        <Grid Grid.Row="7" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="48" SharedSizeGroup="DayCol"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="OffWorkCol"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sun" FontSize="13" VerticalAlignment="Center" Margin="0,4,8,0"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsSundayWorkday, Converter={StaticResource InvertBool}}"
                                      MinWidth="0" Padding="0"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0"/>
                            <ComboBox Grid.Column="3"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      ItemsSource="{Binding WorkTimeOptions}"
                                      IsEnabled="{Binding IsSundayWorkday}"
                                      Text="{Binding SundayStartTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      HorizontalAlignment="Stretch" Margin="0,4,0,0"/>
                        </Grid>
                        <ComboBox Grid.Row="7" Grid.Column="2"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  ItemsSource="{Binding WorkTimeOptions}"
                                  IsEnabled="{Binding IsSundayWorkday}"
                                  Text="{Binding SundayEndTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  HorizontalAlignment="Stretch" Margin="0,4,0,0"/>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <!-- Plain 50/50 split with the same 8px gap as the
                             schedule grid above. Save's right edge lines up
                             with the Start time combo's right edge; Sync now's
                             left edge lines up with the End time combo's left
                             edge \u2014 all four are at the same midpoint. -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding SaveWorkScheduleCommand}"
                                IsEnabled="{Binding HasUnsavedScheduleChanges}"
                                Style="{StaticResource AccentButtonStyle}"
                                Height="40" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                ToolTip="Save the schedule above and apply it immediately. The button stays disabled while there are no unsaved changes.">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="✓ Saved"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasUnsavedScheduleChanges}" Value="True">
                                                <Setter Property="Text" Value="💾 Save schedule"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                        <Button Grid.Column="2"
                                Content="🔄 Sync now"
                                Command="{Binding SyncNowCommand}"
                                Height="40" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                ToolTip="Re-evaluate the current state and push the next off-hours window to Outlook so the server keeps switching OOF on/off even when this app isn't running."/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Reply Messages -->
            <Grid Grid.IsSharedSizeScope="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" SharedSizeGroup="ReplyTitle"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="ReplySubtitle"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="🏢 Internal Reply" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Text="Sent to people inside your organization" FontSize="12" Opacity="0.6"
                                   VerticalAlignment="Center" Margin="0,4,0,8"/>
                        <TextBox Grid.Row="2"
                                 Text="{Binding InternalReply, UpdateSourceTrigger=PropertyChanged}"
                                 Height="180"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 ui:ControlHelper.PlaceholderText="Enter the internal auto-reply message..."
                                 FontSize="14"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" SharedSizeGroup="ReplyTitle"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="ReplySubtitle"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="🌐 External Reply" FontSize="16" FontWeight="Bold"/>
                        <StackPanel Grid.Row="1" Margin="0,4,0,8">
                            <TextBlock Text="Sent to contacts outside your organization" FontSize="12" Opacity="0.6"/>
                            <!-- Toggle on its own line so the dual-label
                                 framing has room to breathe (the switch + two
                                 labels together are too wide to share a row
                                 with the subtitle). -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                        ToolTip="Right (anyone outside): any external sender, including strangers and spammers, gets the reply.&#x0a;Left (my contacts only): only people in your Contacts get the reply, which avoids spam validation and reduces phishing exposure.">
                                <TextBlock Text="my contacts only" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Opacity" Value="1.0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ExternalAudienceAll}" Value="True">
                                                    <Setter Property="Opacity" Value="0.45"/>
                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ui:ToggleSwitch IsOn="{Binding ExternalAudienceAll, Mode=TwoWay}"
                                                 OnContent="" OffContent=""
                                                 MinWidth="0"
                                                 Width="44"
                                                 Padding="0"/>
                                <TextBlock Text="anyone outside" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Opacity" Value="0.45"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ExternalAudienceAll}" Value="True">
                                                    <Setter Property="Opacity" Value="1.0"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <TextBox Grid.Row="2"
                                 Text="{Binding ExternalReply, UpdateSourceTrigger=PropertyChanged}"
                                 Height="180"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 ui:ControlHelper.PlaceholderText="Enter the external auto-reply message..."
                                 FontSize="14"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Action Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="💾 Save Settings"
                        Command="{Binding SaveOofCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Height="48" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
                <Button Grid.Column="2" Content="📋 Save as Template"
                        Command="{Binding SaveAsTemplateCommand}"
                        Height="48" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
            </Grid>

            <!-- Templates Card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Margin="0">
                    <TextBlock Text="📁 My Templates" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Click a template to load it" FontSize="12" Opacity="0.6" Margin="0,4,0,8"/>

                    <ItemsControl ItemsSource="{Binding Templates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:OofTemplate}">
                                <Border CornerRadius="8" BorderThickness="1"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        Padding="12" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       FontSize="11" Opacity="0.5"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Load"
                                                Command="{Binding DataContext.LoadTemplateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Margin="8,0,4,0"
                                                Padding="12,4"/>
                                        <Button Grid.Column="2" Content="🗑️"
                                                Command="{Binding DataContext.DeleteTemplateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,4"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No templates yet. Save your current settings as a template to get started."
                               FontSize="13" Opacity="0.5"
                               HorizontalAlignment="Center" Margin="0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Templates.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
