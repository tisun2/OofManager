<Page x:Class="OofManager.Wpf.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:models="clr-namespace:OofManager.Wpf.Models"
      Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
      Title="OOF Manager">
    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <StackPanel.Resources>
                <Style TargetType="StackPanel">
                    <Setter Property="Margin" Value="0,0,0,16"/>
                </Style>
            </StackPanel.Resources>

            <!-- User Info Card -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0">
                        <TextBlock Text="{Binding UserDisplayName}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="{Binding UserEmail}" FontSize="13" Opacity="0.6"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="📥 Hide to Tray"
                            Command="{Binding HideToTrayCommand}"
                            ToolTip="Hide window to system tray; the app keeps running in the background"
                            VerticalAlignment="Center"
                            Padding="14,4"
                            Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="Sign Out"
                            Command="{Binding LogoutCommand}"
                            VerticalAlignment="Center"
                            Padding="14,4"/>
                </Grid>
            </Border>

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Opacity="0.7"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap"/>

            <!-- Quick Toggle Card -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0">
                        <TextBlock Text="Out of Office" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrentStatus, Converter={StaticResource OofStatusToText}}"
                                   FontSize="18" FontWeight="SemiBold" Opacity="0.85" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1"
                                     IsOn="{Binding IsOofEnabled, Mode=TwoWay}"
                                     VerticalAlignment="Center"/>

                    <Button Grid.Row="1" Grid.ColumnSpan="2"
                            Content="⚡ Save Now"
                            Command="{Binding QuickToggleCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Height="44"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,12,0,0"/>
                </Grid>
            </Border>

            <!-- Work Schedule Card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Margin="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0">
                            <TextBlock Text="🗓️ Work Schedule" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{Binding WorkScheduleStatus}" FontSize="12" Opacity="0.65" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1"
                                         IsOn="{Binding IsWorkScheduleEnabled, Mode=TwoWay}"/>
                    </Grid>

                    <TextBlock Text="Check the boxes for workdays. During working hours on workdays OOF is turned off; outside those hours OOF is turned on automatically."
                               FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                               Margin="0,8,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Mon" HorizontalAlignment="Left" FontSize="12"/>
                            <CheckBox IsChecked="{Binding IsMondayWorkday}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Tue" HorizontalAlignment="Left" FontSize="12"/>
                            <CheckBox IsChecked="{Binding IsTuesdayWorkday}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Wed" HorizontalAlignment="Left" FontSize="12"/>
                            <CheckBox IsChecked="{Binding IsWednesdayWorkday}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="Thu" HorizontalAlignment="Left" FontSize="12"/>
                            <CheckBox IsChecked="{Binding IsThursdayWorkday}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                            <TextBlock Text="Fri" HorizontalAlignment="Left" FontSize="12"/>
                            <CheckBox IsChecked="{Binding IsFridayWorkday}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                            <TextBlock Text="Sat" HorizontalAlignment="Left" FontSize="12"/>
                            <CheckBox IsChecked="{Binding IsSaturdayWorkday}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                            <TextBlock Text="Sun" HorizontalAlignment="Left" FontSize="12"/>
                            <CheckBox IsChecked="{Binding IsSundayWorkday}" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Work Start Time" FontSize="12" Opacity="0.7"/>
                        <TextBlock Grid.Column="2" Text="Work End Time" FontSize="12" Opacity="0.7"/>
                        <ComboBox Grid.Row="1" Grid.Column="0"
                                  ItemsSource="{Binding WorkTimeOptions}"
                                  SelectedItem="{Binding WorkStartTime, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,4,0,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource TimeSpanToHourMinute}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox Grid.Row="1" Grid.Column="2"
                                  ItemsSource="{Binding WorkTimeOptions}"
                                  SelectedItem="{Binding WorkEndTime, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,4,0,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource TimeSpanToHourMinute}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Save and Apply"
                                Command="{Binding SaveWorkScheduleCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Height="40" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"/>
                        <Button Grid.Column="2"
                                Content="Check Now"
                                Command="{Binding ApplyWorkScheduleCommand}"
                                Height="40" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Reply Messages -->
            <Grid Grid.IsSharedSizeScope="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" SharedSizeGroup="ReplyTitle"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="ReplySubtitle"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="🏢 Internal Reply" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Text="Sent to people inside your organization" FontSize="12" Opacity="0.6"
                                   VerticalAlignment="Center" Margin="0,4,0,8"/>
                        <TextBox Grid.Row="2"
                                 Text="{Binding InternalReply, UpdateSourceTrigger=PropertyChanged}"
                                 Height="180"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 ui:ControlHelper.PlaceholderText="Enter the internal auto-reply message..."
                                 FontSize="14"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" SharedSizeGroup="ReplyTitle"/>
                            <RowDefinition Height="Auto" SharedSizeGroup="ReplySubtitle"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="🌐 External Reply" FontSize="16" FontWeight="Bold"/>
                        <Grid Grid.Row="1" Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Sent to contacts outside your organization" FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="All senders" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ui:ToggleSwitch IsOn="{Binding ExternalAudienceAll, Mode=TwoWay}"
                                                 OnContent="" OffContent=""/>
                            </StackPanel>
                        </Grid>
                        <TextBox Grid.Row="2"
                                 Text="{Binding ExternalReply, UpdateSourceTrigger=PropertyChanged}"
                                 Height="180"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 ui:ControlHelper.PlaceholderText="Enter the external auto-reply message..."
                                 FontSize="14"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Action Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="💾 Save Settings"
                        Command="{Binding SaveOofCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Height="48" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
                <Button Grid.Column="2" Content="📋 Save as Template"
                        Command="{Binding SaveAsTemplateCommand}"
                        Height="48" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
            </Grid>

            <!-- Templates Card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Margin="0">
                    <TextBlock Text="📁 My Templates" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Click a template to load it" FontSize="12" Opacity="0.6" Margin="0,4,0,8"/>

                    <ItemsControl ItemsSource="{Binding Templates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:OofTemplate}">
                                <Border CornerRadius="8" BorderThickness="1"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        Padding="12" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                       FontSize="11" Opacity="0.5"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Load"
                                                Command="{Binding DataContext.LoadTemplateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Margin="8,0,4,0"
                                                Padding="12,4"/>
                                        <Button Grid.Column="2" Content="🗑️"
                                                Command="{Binding DataContext.DeleteTemplateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,4"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No templates yet. Save your current settings as a template to get started."
                               FontSize="13" Opacity="0.5"
                               HorizontalAlignment="Center" Margin="0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Templates.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
