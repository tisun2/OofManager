<Page x:Class="OofManager.Wpf.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:models="clr-namespace:OofManager.Wpf.Models"
      Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
      Title="OOF Manager">
    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="Padding" Value="16"/>
            <!-- Bottom margin so stacked cards have visible breathing room.
                 Without it sibling cards share an edge and the user can't
                 tell where one section ends and the next begins. -->
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Center the time text inside the editable time-picker ComboBoxes
             (work schedule grid + vacation start/end). HorizontalContentAlignment
             flows through ModernWpf's default ComboBox template to the embedded
             PART_EditableTextBox; the ItemContainerStyle does the same for the
             dropdown rows so the picker stays visually consistent open or closed. -->
        <Style x:Key="TimePickerComboStyle" TargetType="ComboBox">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <!-- Left padding offsets the right-side dropdown chevron so the
                 visible text re-centers under the Off Work checkbox column. -->
            <Setter Property="Padding" Value="16,5,0,7"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">
            <StackPanel.Resources>
                <Style TargetType="StackPanel">
                    <Setter Property="Margin" Value="0,0,0,16"/>
                </Style>
            </StackPanel.Resources>

            <!-- User Info Card -->
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0">
                        <TextBlock Text="{Binding UserDisplayName}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="{Binding UserEmail}" FontSize="13" Opacity="0.6"/>
                    </StackPanel>
                        <Button Grid.Column="1" Content="🔄 Switch account"
                            Command="{Binding SwitchAccountCommand}"
                            ToolTip="Sign out and pick a different Microsoft 365 account"
                            VerticalAlignment="Center"
                            Padding="14,4"
                            Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="📥 Hide to Tray"
                            Command="{Binding HideToTrayCommand}"
                            ToolTip="Hide window to system tray; the app keeps running in the background"
                            VerticalAlignment="Center"
                            Padding="14,4"/>

                    <CheckBox Grid.Row="1" Grid.ColumnSpan="3"
                              IsChecked="{Binding IsStartWithWindowsEnabled, Mode=TwoWay}"
                              Content="🚀 Start with Windows (launch hidden in the tray)"
                              FontSize="12"
                              Margin="0,12,0,0"
                              ToolTip="When on, OofManager launches automatically when you sign in to Windows and starts hidden in the system tray."/>
                </Grid>
            </Border>

            <!-- Status Message -->
            <TextBlock Text="{Binding OofStatusBarMessage}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                       Margin="0,2,0,14"
                       TextWrapping="Wrap"/>

            <!-- OOF Sync mode picker. Sits directly under the status
                 message; the selected mode controls which card appears
                 below (Manual mode or Schedule mode). The Auto-sync
                 checkbox and ⚡ Sync now button apply to both modes; the
                 SyncCardSubtitle text explains what each does in the
                 currently-selected mode. -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Margin="0">
                    <TextBlock Text="🔄 OOF Sync" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SyncCardSubtitle}"
                               FontSize="12" Opacity="0.65"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>

                    <!-- Mode picker. Two RadioButtons in a single group act
                         as a segmented Manual / Schedule control. Both bind
                         to their own proxy property (IsManualMode /
                         IsScheduleMode) which forward to IsWorkScheduleEnabled
                         internally so the existing auto-managed gating,
                         persistence, and side effects keep working without
                         a second source of truth. -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <RadioButton GroupName="OofSyncMode"
                                     IsChecked="{Binding IsScheduleMode, Mode=TwoWay}"
                                     Content="🗓️ Schedule mode"
                                     FontSize="13"
                                     ToolTip="OofManager auto-flips OOF based on the weekly work-hours grid in the Schedule mode card below. The OOF toggle becomes read-only."/>
                        <RadioButton GroupName="OofSyncMode"
                                     IsChecked="{Binding IsManualMode, Mode=TwoWay}"
                                     Content="✋ Manual mode"
                                     FontSize="13"
                                     Margin="20,0,0,0"
                                     ToolTip="You flip OOF on/off yourself in the Manual mode card below. OofManager only writes to Exchange when you click ⚡ Sync now or have Auto-sync enabled (to correct drift from other clients)."/>
                    </StackPanel>

                    <!-- Shared controls: Auto-sync + ⚡ Sync now. Both modes
                         use these — Schedule mode pushes the next off-hours
                         window, Manual mode re-asserts the current toggle
                         state + reply text. The Sync now tooltip is
                         mode-agnostic for the same reason. -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <CheckBox FontSize="12" VerticalAlignment="Center"
                                  IsChecked="{Binding IsAutoRefreshEnabled, Mode=TwoWay}"
                                  Content="🔄 Auto-sync every 5 minutes"
                                  ToolTip="When checked, OofManager runs a background reconcile every 5 minutes. In Schedule mode it re-pushes the next off-hours window so the schedule rolls forward indefinitely. In Manual mode it re-asserts your current on/off state + reply text on Exchange, correcting drift from Outlook desktop / OWA / admins / Power Automate flows."/>
                        <Button Margin="12,0,0,0" Padding="10,4" FontSize="12"
                                Content="⚡ Sync now"
                                Command="{Binding SyncNowCommand}"
                                VerticalAlignment="Center"
                                ToolTip="Force-push to Outlook right now. Schedule mode pushes the next off-hours window; Manual mode re-asserts the current OOF on/off state + reply text."/>
                    </StackPanel>

                        <TextBlock Text="{Binding StatusMessage}"
                               Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibility}}"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>

                    <!-- Divider between the shared OOF Sync header and the
                         mode-specific lower half. Used to be three stacked
                         cards (OOF Sync + Manual mode + Schedule mode);
                         folded into one card so the mode picker and the
                         content it drives read as a single visual unit. -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="0,1,0,0" Margin="0,16,0,0"/>

                    <!-- Lower half — Manual mode subsection. Holds the OOF
                         on/off toggle (user-controlled in this mode), the
                         cloud-sync reminder banner, the Update reply
                         messages button, and the Long Vacation / Holiday
                         override sub-section. The section title used to be
                         "✋ Manual mode" but the radio button above already
                         says that, so it's been dropped — the dynamic
                         OofCardSubtitle below is the only header we need. -->
                    <Grid Margin="0,16,0,0"
                          Visibility="{Binding IsManualMode, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0">
                        <!-- Sub-caption is the single source of "what mode am
                             I in / what will my action do?" The bold status
                             line that used to live here ("Disabled / Enabled
                             / Scheduled") was redundant with the switch on
                             the right, so it's been folded into this caption
                             which already says everything users actually need. -->
                        <TextBlock Text="{Binding OofCardSubtitle}"
                                   FontSize="12" Opacity="0.65"
                                   TextWrapping="Wrap"/>

                        <!-- Manual-control reminder. When the user turns
                             Work Schedule off they regain full manual
                             control of the OOF toggle here — but any Power
                             Automate flow they previously imported still
                             runs inside their M365 tenant on its own
                             schedule and will silently re-flip OOF behind
                             their back. Surface this exactly when manual
                             mode kicks in so they remember to disable the
                             flow in Power Automate too. -->
                        <Border Background="#FFF8E1" BorderBrush="#F4B400" BorderThickness="0,0,0,2"
                                CornerRadius="4" Padding="10,8" Margin="0,10,0,0"
                                Visibility="{Binding IsOofAutoManaged, Converter={StaticResource InvertBoolToVisibility}}">
                            <TextBlock FontSize="11" TextWrapping="Wrap">
                                ⚠️ If you previously imported the Cloud Sync (Power Automate) solution, turn that flow OFF in make.powerautomate.com — it runs in Microsoft 365 independently and will keep changing your OOF on its own schedule while you're in manual control.
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Toggle: disabled (read-only state indicator) when the
                         Work Schedule is in charge AND Auto-sync is on. When
                         Auto-sync is off the user is in manual control even
                         if the schedule rule is technically enabled, so the
                         toggle becomes interactive again. -->
                    <ui:ToggleSwitch Grid.Column="1"
                                     IsOn="{Binding IsOofEnabled, Mode=TwoWay}"
                                     IsEnabled="{Binding IsOofAutoManaged, Converter={StaticResource InvertBool}}"
                                     VerticalAlignment="Center"/>

                    <!-- "Update reply messages" appears only when (a) the
                         user is in manual mode AND (b) they've edited the
                        reply text since the last commit. The OOF on/off
                        toggle is deferred to ⚡ Sync now / Auto-sync, so
                        this button only pushes edited reply bodies while
                        preserving Outlook's current on/off/window state. -->
                    <Button Grid.Row="1" Grid.ColumnSpan="2"
                            Content="💾 Update reply messages"
                            Command="{Binding QuickToggleCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Height="44"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,12,0,0"
                            ToolTip="Push edited reply messages to Outlook. The on/off switch is pushed by ⚡ Sync now or Auto-sync."
                            Visibility="{Binding CanShowSaveNow, Converter={StaticResource BoolToVisibility}}"/>

                    <!-- Long Vacation / Holiday sub-section. Used to be its
                         own card; folded in here because it writes to the
                         exact same Exchange OOF window as the toggle above,
                         and users were confused that "Out of Office" and
                         "Long Vacation" looked like two unrelated features.
                         When active, the vacation owns the OOF window for
                         its whole stretch (single multi-day Scheduled block
                         on Exchange) and pauses per-day Work Schedule
                         auto-sync so the two rules don't fight. -->
                    <Border Grid.Row="2" Grid.ColumnSpan="2"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,12,0,0"
                            Margin="0,16,0,0">
                        <StackPanel Margin="0" Grid.IsSharedSizeScope="True">
                            <!-- Section header doubles as the on/off control:
                                 unchecked collapses the From/To pickers and
                                 helper text below. Checking the box does NOT
                                 push to Outlook on its own — the vacation
                                 window is committed on the next ⚡ Sync now
                                 click or 5-min auto-sync tick (matches the
                                 deferred-sync model the rest of Manual mode
                                 already uses). -->
                            <CheckBox Content="🏖️ Long Vacation / Holiday"
                                      IsChecked="{Binding IsVacationWindowActive, Mode=TwoWay}"
                                      IsEnabled="{Binding CanToggleVacationWindow}"
                                      FontSize="14" FontWeight="SemiBold"
                                      HorizontalAlignment="Left"
                                      ToolTip="Plan a single multi-day Scheduled OOF window. Checking the box doesn't push to Outlook immediately — click ⚡ Sync now or enable Auto-sync to commit the vacation."/>

                            <!-- Status line: shown only when a vacation
                                 window is currently active on the server.
                                 Replaces the separate "vacation active"
                                 sub-panel that used to host its own End-
                                 vacation button — ending a vacation is now
                                 just unchecking the title checkbox above
                                 (followed by a sync). -->
                            <TextBlock Text="{Binding VacationStatus}"
                                       Visibility="{Binding IsOnLongVacation, Converter={StaticResource BoolToVisibility}}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                       Margin="0,8,0,0" TextWrapping="Wrap"/>

                            <!-- Everything below the checkbox is collapsed
                                 when the user hasn't planned a vacation,
                                 so an empty section is literally just the
                                 header line. -->
                            <StackPanel Visibility="{Binding IsVacationWindowActive, Converter={StaticResource BoolToVisibility}}">
                                <!-- Helper tip: only shown when no vacation
                                     is currently active on the server yet.
                                     Once it's live the VacationStatus line
                                     above already says everything we need. -->
                                <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.65"
                                           Margin="0,8,0,12"
                                           Visibility="{Binding IsOnLongVacation, Converter={StaticResource InvertBoolToVisibility}}">
                                    Push a single multi-day Scheduled OOF for a holiday or extended leave. Click <Run FontWeight="SemiBold">⚡ Sync now</Run> above (or enable Auto-sync) to commit it to Outlook. Tip: load a saved template from <Run FontStyle="Italic">My Templates</Run> first if you want a vacation-specific reply — whatever is in the Internal/External boxes at sync time gets sent.
                                </TextBlock>

                                <!-- Date pickers. Disabled while a vacation
                                     is already live on the server so the
                                     user has to clear the current window
                                     first (uncheck + sync) before editing
                                     the dates — prevents accidentally
                                     rewriting an in-flight Scheduled OOF. -->
                                <Grid IsEnabled="{Binding IsOnLongVacation, Converter={StaticResource InvertBool}}">
                                    <!-- Two halves of the row are From-block | To-block,
                                         separated by an arrow. Inside each half the
                                         label sits next to a DatePicker + small time
                                         combo so a vacation window reads naturally
                                         left-to-right: "From [date] [time] → To
                                         [date] [time]". -->
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- From group -->
                                    <Grid Grid.Column="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="From" FontSize="12" Opacity="0.7"
                                                   VerticalAlignment="Center"/>
                                        <DatePicker Grid.Column="2"
                                                    x:Name="VacationStartDatePicker"
                                                    SelectedDate="{Binding VacationStartDate, Mode=TwoWay}"
                                                    HorizontalAlignment="Stretch"/>
                                        <ComboBox Grid.Column="4"
                                                  Style="{StaticResource TimePickerComboStyle}"
                                                  IsEditable="True" IsTextSearchEnabled="True"
                                                  ItemsSource="{Binding WorkTimeOptions}"
                                                  Text="{Binding VacationStartTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                  HorizontalAlignment="Stretch"/>
                                    </Grid>

                                    <!-- Range arrow rendered as a 1px Border + small
                                         triangle, not a Unicode glyph: the font-stack
                                         was inserting visible gaps between U+2500 box
                                         chars on this machine, breaking the line into
                                         dashes. A Border draws a continuous pixel
                                         line under any font. -->
                                    <Grid Grid.Column="1" Margin="24,0,24,0" VerticalAlignment="Center" MinWidth="40">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Height="1"
                                                Background="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                Opacity="0.5" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="▶" FontSize="9" Opacity="0.5"
                                                   VerticalAlignment="Center" Margin="-1,0,0,0"/>
                                    </Grid>

                                    <!-- To group -->
                                    <Grid Grid.Column="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="To" FontSize="12" Opacity="0.7"
                                                   VerticalAlignment="Center"/>
                                        <DatePicker Grid.Column="2"
                                                    x:Name="VacationEndDatePicker"
                                                    SelectedDate="{Binding VacationEndDate, Mode=TwoWay}"
                                                    HorizontalAlignment="Stretch"/>
                                        <ComboBox Grid.Column="4"
                                                  Style="{StaticResource TimePickerComboStyle}"
                                                  IsEditable="True" IsTextSearchEnabled="True"
                                                  ItemsSource="{Binding WorkTimeOptions}"
                                                  Text="{Binding VacationEndTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                  HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    </Grid>

                    <!-- Lower half — Schedule mode subsection. Holds the
                         schedule status caption, the always-on cloud sync
                         setup, the weekly hours grid, and the Save changes
                         button. The radio button above carries the "Schedule
                         mode" label so the inline header has been dropped. -->
                    <StackPanel Margin="0,16,0,0" Grid.IsSharedSizeScope="True"
                                Visibility="{Binding IsScheduleMode, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding WorkScheduleStatus}"
                                   FontSize="12" Opacity="0.65"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                    <!-- Weekly hours editor laid out horizontally: 1 label
                         column + 7 day columns × 4 rows (day name, Off Work
                         checkbox, Work Start, Work End). Comparing the seven
                         days side-by-side is the natural reading direction
                         for "Mon–Fri 9–18, weekend off"; vertical 7-row
                         scrolling forced the eye to walk down a tall list. -->
                    <TextBlock Text="Tick a day's &quot;Off Work&quot; box for non-working days. Each working day's hours can be set independently."
                               FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                               Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Day name header row. Bold so it reads as a column
                             header rather than another data row. -->
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Mon" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Center" Margin="2,0,2,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Tue" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Center" Margin="2,0,2,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Wed" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Center" Margin="2,0,2,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="Thu" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Center" Margin="2,0,2,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="6" Text="Fri" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Center" Margin="2,0,2,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="7" Text="Sat" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Center" Margin="2,0,2,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="8" Text="Sun" FontSize="12" FontWeight="SemiBold" Opacity="0.7" HorizontalAlignment="Center" Margin="2,0,2,4"/>

                        <!-- Off Work row. The IsChecked binding still targets
                             IsXxxWorkday with InvertBool so an unchecked box
                             == working day (matches the previous semantics). -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Off Work" FontSize="12" Opacity="0.7" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <CheckBox Grid.Row="1" Grid.Column="2" IsChecked="{Binding IsMondayWorkday, Converter={StaticResource InvertBool}}"    MinWidth="0" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,4,2,0"/>
                        <CheckBox Grid.Row="1" Grid.Column="3" IsChecked="{Binding IsTuesdayWorkday, Converter={StaticResource InvertBool}}"   MinWidth="0" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,4,2,0"/>
                        <CheckBox Grid.Row="1" Grid.Column="4" IsChecked="{Binding IsWednesdayWorkday, Converter={StaticResource InvertBool}}" MinWidth="0" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,4,2,0"/>
                        <CheckBox Grid.Row="1" Grid.Column="5" IsChecked="{Binding IsThursdayWorkday, Converter={StaticResource InvertBool}}"  MinWidth="0" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,4,2,0"/>
                        <CheckBox Grid.Row="1" Grid.Column="6" IsChecked="{Binding IsFridayWorkday, Converter={StaticResource InvertBool}}"    MinWidth="0" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,4,2,0"/>
                        <CheckBox Grid.Row="1" Grid.Column="7" IsChecked="{Binding IsSaturdayWorkday, Converter={StaticResource InvertBool}}"  MinWidth="0" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,4,2,0"/>
                        <CheckBox Grid.Row="1" Grid.Column="8" IsChecked="{Binding IsSundayWorkday, Converter={StaticResource InvertBool}}"    MinWidth="0" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,4,2,0"/>

                        <!-- Start time row -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Start" FontSize="12" Opacity="0.7" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <ComboBox Grid.Row="2" Grid.Column="2" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsMondayWorkday}"    Text="{Binding MondayStartTime,    Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="2" Grid.Column="3" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsTuesdayWorkday}"   Text="{Binding TuesdayStartTime,   Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="2" Grid.Column="4" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsWednesdayWorkday}" Text="{Binding WednesdayStartTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="2" Grid.Column="5" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsThursdayWorkday}"  Text="{Binding ThursdayStartTime,  Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="2" Grid.Column="6" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsFridayWorkday}"    Text="{Binding FridayStartTime,    Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="2" Grid.Column="7" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsSaturdayWorkday}"  Text="{Binding SaturdayStartTime,  Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="2" Grid.Column="8" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsSundayWorkday}"    Text="{Binding SundayStartTime,    Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>

                        <!-- End time row -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="End" FontSize="12" Opacity="0.7" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <ComboBox Grid.Row="3" Grid.Column="2" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsMondayWorkday}"    Text="{Binding MondayEndTime,    Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="3" Grid.Column="3" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsTuesdayWorkday}"   Text="{Binding TuesdayEndTime,   Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="3" Grid.Column="4" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsWednesdayWorkday}" Text="{Binding WednesdayEndTime, Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="3" Grid.Column="5" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsThursdayWorkday}"  Text="{Binding ThursdayEndTime,  Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="3" Grid.Column="6" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsFridayWorkday}"    Text="{Binding FridayEndTime,    Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="3" Grid.Column="7" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsSaturdayWorkday}"  Text="{Binding SaturdayEndTime,  Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                        <ComboBox Grid.Row="3" Grid.Column="8" Style="{StaticResource TimePickerComboStyle}" IsEditable="True" IsTextSearchEnabled="True" ItemsSource="{Binding WorkTimeOptions}" IsEnabled="{Binding IsSundayWorkday}"    Text="{Binding SundayEndTime,    Converter={StaticResource TimeSpanToHourMinute}, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" HorizontalAlignment="Stretch" Margin="2,4,2,0"/>
                    </Grid>

                    <!-- Small \"Save changes\" button. Only surfaces after the user edits the
                        grid (workday checkboxes, start/end times). The mode picker
                        covers the schedule on/off path; this button exists solely
                        to push pending grid edits without forcing the user to
                         toggle off-and-on. Hidden when nothing's pending so the card stays
                         visually quiet during normal use. -->
                    <Button Margin="0,12,0,0"
                            Padding="14,6"
                            HorizontalAlignment="Right"
                            Content="💾 Save changes"
                            Command="{Binding SaveWorkScheduleCommand}"
                            ToolTip="Save the edited work schedule and immediately push the next off-hours window to Outlook so the rule reflects your latest grid edits.">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding HasUnsavedScheduleChanges}" Value="True"/>
                                            <Condition Binding="{Binding IsWorkScheduleEnabled}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Cloud sync setup. The local auto-toggle above only works when this PC is on
                         (with the app or its background scheduled task running). For users who want
                         their OOF window to keep advancing even when ALL their computers are off,
                         the buttons below set up a Power Automate flow inside their M365 account.
                         "Download package" creates a one-click .zip the user uploads to Power
                         Automate; "Manual setup" generates a step-by-step HTML guide as a fallback
                         for tenants where legacy package import is disabled.
                         Shown after the weekly editor so the main schedule
                         controls sit directly under the live status line. -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,12,0,0"
                            Margin="0,12,0,0">
                        <StackPanel Margin="0">
                            <TextBlock Text="☁️ Always-on cloud schedule (Power Automate)"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="The flow runs inside your Microsoft 365 account, so your OOF schedule keeps updating in Outlook even with every device powered down."
                                       FontSize="11" Opacity="0.75" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <!-- Two equal-width CTAs side-by-side. The
                                 package is the recommended path; the manual
                                 setup guide is the fallback for tenants that
                                 block legacy package import. Equal weight in
                                 the UI because picking the wrong one wastes
                                 the user's time and they can't tell up front
                                 which their tenant supports. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="📦 Generate Power Automate solution"
                                        Command="{Binding GenerateCloudSyncPackageCommand}"
                                        Padding="12,6" HorizontalAlignment="Stretch"
                                        ToolTip="Generates a Power Automate solution package on your Desktop and opens make.powerautomate.com so you can import it. Recommended."/>
                                <Button Grid.Column="2"
                                        Content="📝 Manual setup guide"
                                        Command="{Binding OpenCloudSyncGuideCommand}"
                                        Padding="12,6" HorizontalAlignment="Stretch"
                                        ToolTip="Fallback if your tenant blocks legacy package import. Opens a personalised HTML walkthrough in your browser."/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Reply Messages + Templates. Three cards (Internal reply,
                 External reply, My Templates) used to sit stacked here; they
                 form a single logical unit ("the reply text and the saved
                 versions of it") so they're now one card with two
                 side-by-side editors at the top and the templates list
                 underneath, separated by a divider. The "Save current as
                 template" button stays on the right of the card header so
                 it's unambiguously about "snapshot the current replies
                 into the list below". -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Margin="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="✉️ Reply Messages"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="📋 Save current as template"
                                Command="{Binding SaveAsTemplateCommand}"
                                Padding="10,4" FontSize="12"
                                VerticalAlignment="Center"
                                ToolTip="Save the current Internal &amp; External reply text and external-audience choice as a new reusable template. Doesn't push anything to Outlook."/>
                    </Grid>

                    <!-- Two reply editors side-by-side. SharedSizeGroups keep
                         the title row and subtitle row vertically aligned
                         across the two halves so the TextBox tops line up
                         even if one subtitle wraps. -->
                    <Grid Grid.IsSharedSizeScope="True" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" SharedSizeGroup="ReplyTitle"/>
                                <RowDefinition Height="Auto" SharedSizeGroup="ReplySubtitle"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="🏢 Internal Reply" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Text="Sent to people inside your organization" FontSize="12" Opacity="0.6"
                                       VerticalAlignment="Center" Margin="0,4,0,8"/>
                            <TextBox Grid.Row="2"
                                     Text="{Binding InternalReply, UpdateSourceTrigger=PropertyChanged}"
                                     Height="180"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     ui:ControlHelper.PlaceholderText="Enter the internal auto-reply message..."
                                     FontSize="14"/>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" SharedSizeGroup="ReplyTitle"/>
                                <RowDefinition Height="Auto" SharedSizeGroup="ReplySubtitle"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="🌐 External Reply" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Text="Sent to anyone outside your organization" FontSize="12" Opacity="0.6"
                                       VerticalAlignment="Center" Margin="0,4,0,8"/>
                            <TextBox Grid.Row="2"
                                     Text="{Binding ExternalReply, UpdateSourceTrigger=PropertyChanged}"
                                     Height="180"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     ui:ControlHelper.PlaceholderText="Enter the external auto-reply message..."
                                     FontSize="14"/>
                        </Grid>
                    </Grid>

                    <!-- Templates sub-section — same divider style we use
                         elsewhere on the page to separate sub-sections within
                         a single card. -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,12,0,0"
                            Margin="0,16,0,0">
                        <StackPanel Margin="0">
                            <TextBlock Text="📁 My Templates"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="Click a template to load it" FontSize="12" Opacity="0.6" Margin="0,4,0,8"/>

                            <ItemsControl ItemsSource="{Binding Templates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:OofTemplate}">
                                        <Border CornerRadius="8" BorderThickness="1"
                                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                                Padding="12" Margin="0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0">
                                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                               FontSize="11" Opacity="0.5"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="Load"
                                                        Command="{Binding DataContext.LoadTemplateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="8,0,4,0"
                                                        Padding="12,4"/>
                                                <Button Grid.Column="2" Content="🗑️"
                                                        Command="{Binding DataContext.DeleteTemplateCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,4"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No templates yet. Save your current settings as a template to get started."
                                       FontSize="13" Opacity="0.5"
                                       HorizontalAlignment="Center" Margin="0,12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Templates.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
